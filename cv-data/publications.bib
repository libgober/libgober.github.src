@article{libgoberComprehensiveDatasetFederal2024,
  title = {A Comprehensive Dataset of {{U}}.{{S}}. Federal Laws (1789–2022)},
  author = {Libgober, Brian},
  date = {2024-01-02},
  journaltitle = {Scientific Data},
  shortjournal = {Sci Data},
